# ────────────────────────────────────────────────────────────
#  ⚡ Zynex — Environment Configuration
# ────────────────────────────────────────────────────────────
#  Copy this file to .env and configure as needed.
#  The app works in demo mode without any API keys.
# ────────────────────────────────────────────────────────────

# ── OpenRouter API Key ──────────────────────────────────────
# Optional — the app works in demo mode without this.
# Get a free key at https://openrouter.ai
# Sign up → Dashboard → Keys → Create Key
OPENROUTER_API_KEY=

# ── LLM Model ──────────────────────────────────────────────
# The model to use via OpenRouter.
# Default: google/gemini-2.0-flash-001 (FREE on OpenRouter)
# Other free options:
#   - meta-llama/llama-3.1-8b-instruct:free
#   - mistralai/mistral-7b-instruct:free
# Paid options (better quality):
#   - anthropic/claude-3.5-sonnet
#   - openai/gpt-4o
DEFAULT_MODEL=google/gemini-2.0-flash-001

# ── Server Configuration ───────────────────────────────────
# Host and port for the Uvicorn server
HOST=0.0.0.0
PORT=8000
