# ────────────────────────────────────────────────────────────
#  Zynex — Environment Configuration
# ────────────────────────────────────────────────────────────
#  Copy this file to .env if you want to configure manually.
#  Otherwise, just run the app — the web UI has a one-click
#  "Activate Free AI" button that auto-provisions everything.
# ────────────────────────────────────────────────────────────

# ── OpenRouter API Key ──────────────────────────────────────
# Optional — the app auto-provisions this via the web UI.
# You can also set it manually:
#   1. Go to https://openrouter.ai and create a free account
#   2. Dashboard → Keys → Create Key
#   3. Paste below
OPENROUTER_API_KEY=

# ── LLM Model ──────────────────────────────────────────────
# The default model to use via OpenRouter.
# Default: google/gemini-2.0-flash-001 (FREE on OpenRouter)
# Other free options:
#   - meta-llama/llama-3.3-70b-instruct:free
#   - deepseek/deepseek-r1:free
# Paid options (better quality):
#   - anthropic/claude-3.5-sonnet
#   - openai/gpt-4o
DEFAULT_MODEL=google/gemini-2.0-flash-001

# ── Server Configuration ───────────────────────────────────
HOST=0.0.0.0
PORT=8000
